<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SharpReady.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:SharpReady.Views"
    Title="SharpReady">

    <TabBar>
        <ShellContent
            Title="Home"
            Icon="home.png"
            ContentTemplate="{DataTemplate views:DashboardPage}"
            Route="Home" />

        <ShellContent
            Title="Practice"
            Icon="book.png"
            ContentTemplate="{DataTemplate views:TopicsPage}"
            Route="Practice" />

        <ShellContent
            Title="Quick Quiz"
            Icon="flash.png"
            ContentTemplate="{DataTemplate views:QuickQuizPage}"
            Route="QuickQuiz" />

        <ShellContent
            Title="Progress"
            Icon="chart.png"
            ContentTemplate="{DataTemplate views:ProgressPage}"
            Route="Progress" />

        <ShellContent
            Title="Settings"
            Icon="settings.png"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Route="Settings" />
    </TabBar>

</Shell>
