<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SharpReady.ViewModels"
             x:Class="SharpReady.Views.QuickQuizPage"
             x:DataType="vm:QuickQuizViewModel"
             Title="Quick Quiz"
             Shell.NavBarIsVisible="False">

    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16" Padding="40">
        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           Color="{StaticResource Primary}"
                           HeightRequest="48" WidthRequest="48"/>
        <Label Text="Finding your weakest area..."
               FontSize="16"
               HorizontalTextAlignment="Center"
               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
    </VerticalStackLayout>

</ContentPage>
