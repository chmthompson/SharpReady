<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SharpReady.ViewModels"
             x:Class="SharpReady.Views.QuizResultsPage"
             x:DataType="vm:QuizResultsViewModel"
             Title="Results"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="0">

            <!-- Score card -->
            <Border StrokeShape="RoundRectangle 12" Padding="24"
                    Margin="0,0,0,20"
                    BackgroundColor="{Binding Passed, Converter={StaticResource BoolToPassBgConverter}}">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="{Binding Passed, Converter={StaticResource BoolToPassLabelConverter}}"
                           FontSize="14" HorizontalTextAlignment="Center"
                           TextColor="White"/>
                    <Label Text="{Binding PercentLabel}"
                           FontSize="56" FontFamily="OpenSansSemibold"
                           TextColor="White" HorizontalTextAlignment="Center"/>
                    <Label Text="{Binding ScoreLabel, StringFormat='Score: {0}'}"
                           FontSize="16" TextColor="White" HorizontalTextAlignment="Center"/>
                    <Label Text="{Binding TopicDisplayName}"
                           FontSize="13" TextColor="White" HorizontalTextAlignment="Center" Opacity="0.8"/>
                </VerticalStackLayout>
            </Border>

            <!-- Wrong answers -->
            <Label Text="Review Wrong Answers" Style="{StaticResource SectionHeader}"/>

            <CollectionView ItemsSource="{Binding WrongAnswers}">
                <CollectionView.EmptyView>
                    <Border StrokeShape="RoundRectangle 10" Padding="20" Margin="0,4"
                            BackgroundColor="{StaticResource CorrectGreenLight}">
                        <Label Text="Perfect score! No wrong answers."
                               HorizontalTextAlignment="Center"
                               TextColor="{StaticResource CorrectGreen}"
                               FontFamily="OpenSansSemibold"/>
                    </Border>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:WrongAnswerItem">
                        <Border StrokeShape="RoundRectangle 10" Padding="14" Margin="0,6"
                                Stroke="{StaticResource WrongRedBrush}">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding QuestionText}"
                                       FontFamily="OpenSansSemibold" FontSize="14"/>
                                <Label FontSize="13"
                                       TextColor="{StaticResource WrongRed}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Your answer: "/>
                                            <Span Text="{Binding YourAnswer}" FontAttributes="Bold"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label FontSize="13"
                                       TextColor="{StaticResource CorrectGreen}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Correct: "/>
                                            <Span Text="{Binding CorrectAnswer}" FontAttributes="Bold"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Text="{Binding Explanation}"
                                       FontSize="12" LineHeight="1.4"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"/>

                                <!-- Show example code toggle -->
                                <Label Text="{Binding ExampleCodeLinkText}"
                                       IsVisible="{Binding HasExampleCode}"
                                       TextColor="{StaticResource Primary}"
                                       TextDecorations="Underline"
                                       FontSize="13" Margin="0,4,0,0">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleCodeCommand}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                                <Border StrokeShape="RoundRectangle 8" Padding="0"
                                        BackgroundColor="{StaticResource CodeBackground}"
                                        IsVisible="{Binding ShowCode}">
                                    <Label Text="{Binding ExampleCode}"
                                           Style="{StaticResource CodeLabel}"/>
                                </Border>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Actions -->
            <VerticalStackLayout Spacing="10" Margin="0,24,0,32">
                <Button Text="Practice Again" Command="{Binding PracticeAgainCommand}"/>
                <Button Text="Back to Topics" Command="{Binding BackToTopicsCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Primary}"
                        BorderColor="{StaticResource Primary}"
                        BorderWidth="1"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
